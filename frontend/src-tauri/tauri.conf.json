{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "humanoid-robot",
  "version": "0.1.0",
  "identifier": "com.nexabot.robot",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "humanoid-robot",
        "width": 800,
        "height": 600,
        "resizable": true,
        "fullscreen": false,
        "visible": false,
        "url": "index.html"
      },
      {
        "label": "splashscreen",
        "title": "humanoid-robot",
        "width": 480,
        "height": 340,
        "resizable": false,
        "decorations": false,
        "transparent": true,
        "center": true,
        "url": "splashscreen.html"
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "android": {
      "debugApplicationIdSuffix": ".debug"
    }
  }
}
