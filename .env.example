# =====================================================================
# Robot — sample environment file
# Copy to `.env` and fill in your real keys. `.env` is gitignored.
# =====================================================================

# Anam API - Visual Avatar & Voice Orchestration
ANAM_API_KEY=your_anam_api_key_here

# NVIDIA API - Custom Brain (LLM)
# Get one at: https://build.nvidia.com
NVIDIA_API_KEY=your_nvidia_api_key_here
NVIDIA_MODEL=stepfun-ai/step-3.7-flash

# HTTP port (optional, defaults to 8000)
PORT=8000
