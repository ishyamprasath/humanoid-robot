# =====================================================================
# Robot — sample environment file
# Copy to `.env` and fill in your real keys. `.env` is gitignored.
# =====================================================================

# Gemini Live API — voice + vision brain
# Get one at: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=models/gemini-3.1-flash-live-preview
GEMINI_API_VERSION=v1beta
VOICE_NAME=Kore

# NVIDIA Nemotron — text fallback brain (used server-side only)
# Get one at: https://build.nvidia.com
NVIDIA_API_KEY=your_nvidia_api_key_here
NVIDIA_MODEL=nvidia/nemotron-3-nano-omni-30b-a3b-reasoning

# HTTP port (optional, defaults to 8000)
PORT=8000


VITE_ULTRAVOX_API_KEY=
